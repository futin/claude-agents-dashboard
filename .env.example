# Claude Agents Dashboard — configuration
# Copy to .env and adjust. All values optional (defaults shown).

# Port the dashboard serves on.
PORT=4173

# How many sessions to show, sorted by most-recent activity.
MAX_SESSIONS=5

# A session counts as "working" if its transcript changed within this many
# minutes; otherwise it is shown as "idle".
ACTIVE_WINDOW_MIN=5

# Only consider sessions whose transcript was modified within this many hours.
LOOKBACK_HOURS=24

# Skip the lsof process-liveness gate. Auto: true inside a Docker container
# (can't see the host's claude processes), false otherwise.
# SKIP_PROC_SCAN=false

# Optional: override the context-window size (tokens) used for the % bar.
# Leave unset to auto-detect (1M for Sonnet/Opus/Fable, 200k for Haiku + unknowns).
# CLAUDE_CODE_AUTO_COMPACT_WINDOW=400000
